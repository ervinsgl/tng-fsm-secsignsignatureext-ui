<mvc:View
    controllerName="com.tng.fsm.secsignsignatureext.app.controller.SecSignSignatureExt"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page
        id="page"
        showNavButton="false"
        showHeader="true"
        busy="{view>/busy}"
        busyIndicatorDelay="0">

        <customHeader>
            <OverflowToolbar design="Info">
                <core:Icon src="sap-icon://connected" class="sapUiTinyMarginEnd" />
                <Title text="FSM Web Container" level="H4" />
                <ToolbarSpacer />
                <ObjectStatus
                    text="{= ${view>/context/source} === 'mobile' ? 'Mobile App' : 'Web UI' }"
                    state="Success"
                    visible="{view>/contextLoaded}" />
                <ObjectStatus
                    text="{view>/context/objectType}"
                    state="Information"
                    visible="{view>/contextLoaded}" />
            </OverflowToolbar>
        </customHeader>

        <content>

            <!-- Not opened from FSM -->
            <IllustratedMessage
                visible="{view>/showError}"
                illustrationType="sapIllus-NoMail"
                title="Open from FSM"
                description="Open this app from FSM Mobile (Web Container) or FSM Web UI (Shell Extension)." />

            <layout:VerticalLayout
                visible="{view>/contextLoaded}"
                width="100%"
                class="sapUiContentPadding">

                <!-- ── Attachments table ───────────────────────────────── -->
                <Table
                    id="attachmentsTable"
                    mode="MultiSelect"
                    items="{view>/attachments}"
                    busy="{view>/attachmentsBusy}"
                    busyIndicatorDelay="0"
                    noDataText="No attachments found"
                    selectionChange="onSelectionChange"
                    updateFinished="onTableUpdateFinished"
                    class="sapUiSmallMarginBottom">

                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="Attachments" level="H5" />
                            <ObjectStatus
                                title="{= ${view>/user/firstName} ? (${view>/user/firstName} + ' ' + ${view>/user/lastName}) : ${view>/context/userName} }"
                                text="{view>/context/userName}"
                                icon="sap-icon://person-placeholder"
                                class="sapUiSmallMarginBegin"
                                visible="{= !!${view>/context/userName} }" />
                            <ObjectStatus
                                text="{view>/user/email}"
                                icon="sap-icon://email"
                                class="sapUiSmallMarginBegin"
                                visible="{= !!${view>/user/email} }" />
                            <ToolbarSpacer />
                            <ObjectStatus
                                text="{= ${view>/attachments}.length + ' item(s)'}"
                                visible="{view>/attachmentsLoaded}" />
                            <Button
                                text="{= 'Sign Selected (' + ${view>/selectedCount} + ')'}"
                                icon="sap-icon://signature"
                                type="Emphasized"
                                enabled="{= ${view>/selectedCount} >= 1 }"
                                press="onSignSelectedPress"
                                visible="{view>/attachmentsLoaded}" />
                        </OverflowToolbar>
                    </headerToolbar>

                    <columns>
                        <Column width="8rem">
                            <Text text="" />
                        </Column>
                        <Column>
                            <Text text="File Name" />
                        </Column>
                        <Column width="6rem">
                            <Text text="Type" />
                        </Column>
                        <Column>
                            <Text text="Description" />
                        </Column>
                    </columns>

                    <items>
                        <ColumnListItem>
                            <cells>
                                <Button
                                    text="{= ${view>signed} ? 'Signed!' : 'Sign PDF' }"
                                    type="{= ${view>signed} ? 'Success' : 'Emphasized' }"
                                    enabled="{= !${view>signed} }"
                                    press="onSignPress" />
                                <Link
                                    text="{view>fileName}"
                                    press="onFileNamePress"
                                    wrapping="false" />
                                <Text text="{view>type}" />
                                <Text text="{view>description}" />
                            </cells>
                        </ColumnListItem>
                    </items>

                </Table>

                <!-- ── Inline PDF viewer ───────────────────────────────── -->
                <Panel
                    id="pdfPanel"
                    visible="{= !!${view>/pdfUrl} }"
                    width="100%">

                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="{view>/pdfFileName}" level="H5" />
                            <ToolbarSpacer />
                            <Button
                                text="Close"
                                icon="sap-icon://decline"
                                press="onClosePdf" />
                        </OverflowToolbar>
                    </headerToolbar>

                    <PDFViewer
                        id="pdfViewer"
                        source="{view>/pdfUrl}"
                        isTrustedSource="true"
                        showDownloadButton="true"
                        height="600px"
                        width="100%" />

                </Panel>

            </layout:VerticalLayout>

        </content>

    </Page>
</mvc:View>